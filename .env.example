# .env.example - Crontab Manager 环境变量模板
# 使用方法: cp .env.example .env 然后修改对应值

# Flask 密钥（必须修改）
SECRET_KEY=your-secret-key-change-me

# 服务端口
PORT=5100

# Gunicorn 工作进程数
WORKERS=2

# Gunicorn 每个工作进程的线程数
THREADS=2

# 用户配置（JSON 格式，可选，也可通过 config/config.json 配置）
# CRONTAB_USERS={"admin":{"password":"admin123","role":"admin","machines":["*"]}}

# Flask 调试模式（生产环境请设为 0）
FLASK_DEBUG=0
